{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "sortImports": {
    "groups": [
      "value-builtin",
      "value-external",
      "value-internal",
      ["value-parent", "value-sibling", "value-index"],
      "side_effect_style",
      "side_effect",
      "type",
      "unknown"
    ],
    "internalPattern": ["@/"],
    "ignoreCase": true,
    "newlinesBetween": true,
    "order": "asc"
  },
  "sortTailwindcss": {
    "stylesheet": "./global.css"
  },
  "ignorePatterns": [
    ".expo/**",
    "dist/**",
    "web-build/**",
    "node_modules/**",
    "ios/**",
    "android/**",
    "assets/expo.icon/**",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "pnpm-lock.yaml"
  ]
}
