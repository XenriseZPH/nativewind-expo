{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "sortImports": true,
  "sortTailwindcss": {
    "stylesheet": "./global.css"
  },
  "ignorePatterns": [
    ".expo/**",
    "dist/**",
    "web-build/**",
    "node_modules/**",
    "ios/**",
    "android/**",
    "assets/expo.icon/**",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "pnpm-lock.yaml"
  ]
}
