{
  "languages": {
    "JavaScript": {
      "language_servers": ["oxc", "!eslint", "..."],
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath={buffer_path}"]
        }
      },
      "format_on_save": "on"
    },
    "TypeScript": {
      "language_servers": ["oxc", "!eslint", "..."],
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath={buffer_path}"]
        }
      },
      "format_on_save": "on"
    },
    "TSX": {
      "language_servers": ["oxc", "!eslint", "..."],
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath={buffer_path}"]
        }
      },
      "format_on_save": "on"
    }
  }
}
